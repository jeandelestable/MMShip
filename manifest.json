{
  "manifest_version": 3,
  "name": "MMShip - Shipping label cropper",
  "version": "0.1.0",
  "description": "Local shipping label cropper and printer for DPD, Mondial Relay and DHL",
  "permissions": ["tabs", "activeTab", "scripting", "contextMenus", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "MMShip"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/editor/editor.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
